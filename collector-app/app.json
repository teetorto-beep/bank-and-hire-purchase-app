{
  "expo": {
    "name": "Majupat Collector",
    "slug": "majupat-collector",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#581c87"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.majupat.collector"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#581c87"
      },
      "package": "com.majupat.collector",
      "versionCode": 4,
      "minSdkVersion": 24,
      "permissions": [
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      "expo-system-ui",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#581c87"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 34,
            "buildToolsVersion": "35.0.0",
            "kotlinVersion": "1.9.24"
          }
        }
      ],
      ["./plugins/withGradleVersion", { "gradleVersion": "8.7" }]
    ],
    "extra": {
      "eas": {
        "projectId": "66658ae1-0408-4fb6-8b5e-35481de57dd9"
      }
    },
    "owner": "majupat"
  }
}
